# Don't put your real key here. Set it as a Firebase secret instead:
#   firebase functions:secrets:set RESEND_API_KEY
#
# For LOCAL emulator testing only, create functions/.secret.local with:
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_your_key_here

# QuickBooks Online OAuth (server-side token exchange)
#   firebase functions:secrets:set QB_CLIENT_ID
#   firebase functions:secrets:set QB_CLIENT_SECRET
# Get these from developer.intuit.com → your app → Keys & OAuth.
# The redirect URI registered there must be exactly:
#   https://dunriteconstruction.app/qbo-callback
QB_CLIENT_ID=your_intuit_client_id
QB_CLIENT_SECRET=your_intuit_client_secret
# Optional — defaults to production. Set 'sandbox' while testing.
QB_ENV=production
